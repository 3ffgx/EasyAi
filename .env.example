# 数据库配置
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/easyai
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/easyai

# Redis 配置
REDIS_URL=redis://localhost:6379/0

# JWT 密钥（请修改为随机字符串）
SECRET_KEY=your-secret-key-change-in-production

# DeepSeek API Key
DEEPSEEK_API_KEY=sk-xxx

# 其他模型 API Key（可选）
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
